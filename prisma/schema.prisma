generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum ExerciseCategory {
    STRENGTH
    CONDITIONING
    SKILL
    FLEXIBILITY
    OTHER
}

enum MetricUnit {
    REPS
    SECONDS
    MINUTES
    METERS
    KM
    KG
    LB
    COUNT
}

enum GoalPriority {
    PRIMARY
    SECONDARY
}

enum GoalStatus {
    ACTIVE
    ARCHIVED
}

enum StatType {
    STR
    END
    AGI
    SPD
    PWR
    FLX
    VIT
    DSC
}

enum QuestStatus {
    OFFERED
    PENDING
    COMPLETED
    FAILED
}

model User {
    id        String   @id @default(cuid())
    email     String   @unique
    name      String?
    password  String
    timezone  String   @default("Asia/Jakarta")
    createdAt DateTime @default(now())

    activityTypes       ActivityType[]
    exercises           Exercise[]
    sessions            Session[]
    benchmarks          Benchmark[]
    goals               Goal[]
    stats               Stat[]
    statHistory         StatHistory[]
    quests              Quest[]
    onboardingResponses OnboardingResponse[]
}

model ActivityType {
    id     String  @id @default(cuid())
    userId String
    user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    name   String
    color  String?

    sessions Session[]

    @@unique([userId, name])
}

model Goal {
    id         String       @id @default(cuid())
    userId     String
    user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
    name       String
    priority   GoalPriority @default(SECONDARY)
    status     GoalStatus   @default(ACTIVE)
    targetDate DateTime?
    notes      String?
    createdAt  DateTime     @default(now())
    archivedAt DateTime?

    sessions Session[]

    @@index([userId, status])
}

model Session {
    id             String       @id @default(cuid())
    userId         String
    user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
    date           DateTime
    activityTypeId String
    activityType   ActivityType @relation(fields: [activityTypeId], references: [id])
    goalId         String?
    goal           Goal?        @relation(fields: [goalId], references: [id])
    focus          String?
    duration       Int?
    rpe            Int?
    notes          String?
    createdAt      DateTime     @default(now())

    sessionExercises SessionExercise[]
    quests           Quest[]

    @@index([userId, date])
    @@index([activityTypeId])
}

model Exercise {
    id       String           @id @default(cuid())
    userId   String
    user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
    name     String
    category ExerciseCategory
    unit     MetricUnit
    statTags StatType[]

    sessionExercises SessionExercise[]

    @@unique([userId, name])
}

model SessionExercise {
    id         String   @id @default(cuid())
    sessionId  String
    session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
    exerciseId String
    exercise   Exercise @relation(fields: [exerciseId], references: [id])

    sets  Int?
    reps  Int?
    value Float?
    notes String?

    @@index([sessionId])
}

model Benchmark {
    id     String     @id @default(cuid())
    userId String
    user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    metric String
    value  Float
    unit   MetricUnit
    date   DateTime   @default(now())

    @@index([userId, metric, date])
}

model FitnessStandard {
    id     String     @id @default(cuid())
    metric String
    unit   MetricUnit
    ageMin Int?
    ageMax Int?
    gender String?
    level  String
    value  Float

    @@index([metric, level])
}

model Stat {
    id        String   @id @default(cuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    type      StatType
    value     Float
    updatedAt DateTime @updatedAt

    @@unique([userId, type])
}

model OnboardingResponse {
    id          String   @id @default(cuid())
    userId      String
    user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    questionKey String
    rawAnswer   String
    mappedStat  StatType
    mappedValue Float
    createdAt   DateTime @default(now())

    @@index([userId])
}

model StatHistory {
    id        String   @id @default(cuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    type      StatType
    delta     Float
    reason    String
    questId   String?
    quest     Quest?   @relation(fields: [questId], references: [id])
    createdAt DateTime @default(now())

    @@index([userId, type, createdAt])
}

model Quest {
    id          String      @id @default(cuid())
    userId      String
    user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    date        DateTime    @default(now())
    title       String
    description String?
    targetText  String
    status      QuestStatus @default(OFFERED)
    acceptedAt  DateTime?
    sessionId   String?
    session     Session?    @relation(fields: [sessionId], references: [id])
    createdAt   DateTime    @default(now())
    resolvedAt  DateTime?

    rewards    QuestStatReward[]
    statEvents StatHistory[]

    @@index([userId, date])
}

model QuestStatReward {
    id              String   @id @default(cuid())
    questId         String
    quest           Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
    type            StatType
    completionValue Float
    failurePenalty  Float

    @@index([questId])
}
